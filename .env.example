# Claw Variants Support - select provider with VOICE_CLAW_PROVIDER
# Default provider: openclaw
VOICE_CLAW_PROVIDER=openclaw
VOICE_SESSION_PREFIX=voice
VOICE_GATEWAY_TIMEOUT=30000

# ===== OpenClaw Configuration =====
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your-secure-token
OPENCLAW_AGENT_ID=assistant

# Legacy OpenClaw environment variables (backward compatible)
GATEWAY_URL=http://localhost:18789
GATEWAY_AUTH_TOKEN=your-secure-token
GATEWAY_AGENT_ID=assistant
GATEWAY_SESSION_PREFIX=voice:
GATEWAY_CONNECT_TIMEOUT_MS=5000
GATEWAY_READ_TIMEOUT_MS=30000

# ===== ZeroClaw Configuration =====
# VOICE_CLAW_PROVIDER=zeroclaw
# ZEROCLAW_GATEWAY_URL=http://localhost:3000
# ZEROCLAW_WEBHOOK_TOKEN=webhook-secret

# ===== TinyClaw Configuration =====
# VOICE_CLAW_PROVIDER=tinyclaw
# TINYCLAW_HOME=~/.tinyclaw

# ===== IronClaw Configuration =====
# VOICE_CLAW_PROVIDER=ironclaw
# IRONCLAW_GATEWAY_URL=http://localhost:8888
# IRONCLAW_GATEWAY_TOKEN=bearer-token
# IRONCLAW_USE_WEBSOCKET=true

# ===== MimiClaw Configuration =====
# VOICE_CLAW_PROVIDER=mimiclaw
# MIMICLAW_DEVICE_HOST=192.168.1.100
# MIMICLAW_DEVICE_PORT=18789
# MIMICLAW_USE_WEBSOCKET=true

# ===== PicoClaw Configuration (Early-Stage Framework) =====
# VOICE_CLAW_PROVIDER=picoclaw
# PICOCLAW_HOME=~/.picoclaw/workspace
# PICOCLAW_GATEWAY_URL=http://localhost:9001  # Optional HTTP endpoint
# PICOCLAW_AGENT_ID=default

# ===== NanoBot Configuration (Ultra-Lightweight Python Agent) =====
# VOICE_CLAW_PROVIDER=nanobot
# NANOBOT_HOME=~/.nanobot
# NANOBOT_GATEWAY_URL=http://localhost:18790  # Optional HTTP endpoint
# NANOBOT_AGENT_ID=default

# Whisper STT Service
WHISPER_URL=http://localhost:8086
WHISPER_LANGUAGE=en
WHISPER_MODEL=base

# Piper TTS Service
PIPER_URL=http://localhost:5002
PIPER_VOICE_ID=en_US-amy-medium

# Audio Configuration
# Audio capture device (Linux: PulseAudio/ALSA device name)
AUDIO_CAPTURE_DEVICE=default

# Audio playback device (Linux ALSA only - used when AUDIO_PLAYBACK=alsa)
# For PulseAudio playback, this is ignored
AUDIO_PLAYBACK_DEVICE=default

# Audio playback mode (auto|pulse|alsa)
AUDIO_PLAYBACK=auto

AUDIO_SAMPLE_RATE=16000
# Audio Capture Behavior & Pause Handling
# The voice service uses frame history to ensure continuous audio capture across pauses.
# This allows for two-utterance scenarios (wake word + command with pause):
#   1. User says "hey assistant" [pause] "turn on the lights"
#   2. System captures wake word + pause audio + command audio contiguously
#   3. Wake word transcript is stripped, command forwarded to gateway
#   4. Works with Whisper (produces transcripts) or OpenWakeWord (audio-only)
# Frame history: Keeps 24 seconds of audio to bridge pauses
# Pre-roll: 300ms of audio before speech start for smoother transitions
# Max listen: 10 seconds before timing out waiting for speech

# VAD (Voice Activity Detection)
# Balanced tuning for clear speech detection while rejecting ambient noise
# Standard silence threshold = speech must rise clearly above noise floor
VAD_SILENCE_THRESHOLD=1.2

# Noise floor threshold - minimum RMS level to consider as potential speech
VAD_NOISE_FLOOR_THRESHOLD=0.01

# Minimum speech duration to register as speech (ms)
# Require 50ms of audio to avoid false triggers from brief noise
VAD_MIN_SPEECH_MS=50

# Gap of silence before ending speech detection (ms)
# 800ms allows pauses between wake word and command
VAD_MIN_SILENCE_MS=800

# Moderate RMS threshold = detects normal speech without ambient noise
# This is the absolute threshold for speech energy
VAD_ABSOLUTE_RMS=0.003

# Absolute RMS threshold below which speech stops (default 0)
# Below this level, always consider it silence (avoids noise)
VAD_ABSOLUTE_SILENCE_RMS=0.0015

# Enable debug logging for VAD decisions (rms, threshold, speaking state)
VAD_DEBUG=true

# Post-TTS listen window (ms) to capture speech immediately after playback ends
POST_TTS_LISTEN_MS=1500

# Echo Cancellation Configuration
# Removes TTS playback from microphone input to prevent false cut-in detection
# Uses cross-correlation time alignment and static subtraction
ECHO_CANCEL=false                    # Enable/disable echo cancellation
ECHO_CANCEL_ATTENUATION=0.7          # How much to subtract (0.0-1.0)
ECHO_CANCEL_TAIL_LENGTH=150          # Max echo delay to model (ms)
ECHO_CANCEL_RECALIBRATE_INTERVAL=0   # Auto-recalibrate delay every N ms (0=disabled)
ECHO_CANCEL_MIN_CORRELATION=0.3      # Minimum correlation to accept alignment

# Cut-In Configuration (interrupt detection when user speaks during TTS)
# Cut-in detects when user starts speaking to interrupt assistant's response
# Moderate RMS threshold = detects speech interrupts
CUTIN_ABSOLUTE_RMS=0.0045

# Minimum speech duration before interrupt is triggered (ms)
# 100ms prevents false triggers from brief sounds, allows "stop"
CUTIN_MIN_SPEECH_MS=100

# TTS-aware cut-in gate (stricter during playback to ignore leakage)
# Raised to 0.008 to reduce false triggers from TTS output
CUTIN_TTS_ABSOLUTE_RMS=0.008
CUTIN_TTS_MIN_SPEECH_MS=300

# Logging
LOG_LEVEL=info
METRICS_ENABLED=false

# Optional: For production monitoring
SENTRY_DSN=

# Wake word timeout system (optional)
# WAKE_WORD can be a single phrase or a JSON array of phrases, e.g. ["hey openclaw","ok assistant"]
WAKE_WORD=
# Time in ms before system goes to sleep after last activity (default 120000 = 2 minutes)
# Increase for longer conversations without repeating wake word
WAKE_WORD_TIMEOUT=120000
# Fuzzy matching threshold for wake word detection (0.0 to 1.0)
# 1.0 = exact match only, 0.75 (default) = 75% similarity, 0.6 = very permissive
# Set lower values to match typos/slurred speech: "hey assitant" vs "hey assistant"
# Set higher values for stricter matching to avoid false positives
WAKE_WORD_FUZZY_THRESHOLD=0.75

# Wake Word Detection Engine (whisper | openwakeword)
# whisper (default): Uses full speech-to-text, then text matching on wake word
# openwakeword: Uses lightweight audio fingerprinting for fast wake word detection only
WAKE_WORD_ENGINE=whisper

# OpenWakeWord Configuration (when WAKE_WORD_ENGINE=openwakeword)
# URL to openWakeWord HTTP service
OPENWAKEWORD_URL=http://localhost:8082
# Confidence threshold (0.0-1.0): Higher = stricter matching, lower = more permissive
OPENWAKEWORD_CONFIDENCE_THRESHOLD=0.5
# Enable debug logging for openWakeWord detection
OPENWAKEWORD_ENABLE_DEBUG=false

SLEEP_PHRASE=go to sleep
SLEEP_PHRASE=go to sleep

# Voice control HTTP server
VOICE_HTTP_PORT=18910
