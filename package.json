{
  "name": "openclaw-voice",
  "version": "0.1.0",
  "description": "Stateless voice orchestration service for OpenClaw Gateway - HTTP hooks based",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:wasapi": "node-gyp rebuild",
    "install": "node scripts/optional-build.js",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest",
    "test:integration": "vitest integration",
    "clean": "rm -rf dist build",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "node-fetch": "^3.3.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "node-addon-api": "^7.0.0",
    "node-gyp": "^10.0.0"
  },
  "optionalDependencies": {
    "wasapi-bindings": "file:."
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "gypfile": true
}
